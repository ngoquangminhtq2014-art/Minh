-- SKELETON ESP
local espCache = {}
local BonePairs = {
   {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
   {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
   {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
   {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
   {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"},
   {"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"},
   {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
}

local function ClearESPForPlayer(player)
   if espCache[player] then
      if espCache[player].Connection then espCache[player].Connection:Disconnect() end
      if espCache[player].Lines then
         for _, line in pairs(espCache[player].Lines) do line:Destroy() end
      end
      espCache[player] = nil
   end
end

local function TrackESP(player)
   if player == LocalPlayer then return end
   ClearESPForPlayer(player)

   local lines = {}
   for i = 1, #BonePairs do
      local line = Drawing.new("Line")
      line.Color = Color3.fromRGB(0, 255, 0)
      line.Thickness = 1.5
      line.Visible = false
      table.insert(lines, line)
   end

   local connection
   connection = RunService.RenderStepped:Connect(function()
      if not espEnabled or not player.Parent then
         for _, line in pairs(lines) do line.Visible = false end
         if not espEnabled and connection then 
            connection:Disconnect()
         end
         return
      end

      local char = player.Character
      local hum = char and char:FindFirstChild("Humanoid")
      
      if char and hum and hum.Health > 0 then
         local lineIndex = 1
         for _, pair in pairs(BonePairs) do
            local part1 = char:FindFirstChild(pair[1])
            local part2 = char:FindFirstChild(pair[2])
            if part1 and part2 then
               local pos1, onScreen1 = Camera:WorldToViewportPoint(part1.Position)
               local pos2, onScreen2 = Camera:WorldToViewportPoint(part2.Position)
               if onScreen1 and onScreen2 then
                  local currentLine = lines[lineIndex]
                  if currentLine then
                     currentLine.From = Vector2.new(pos1.X, pos1.Y)
                     currentLine.To = Vector2.new(pos2.X, pos2.Y)
                     currentLine.Visible = true
                     lineIndex = lineIndex + 1
                  end
               end
            end
         end
         for i = lineIndex, #lines do lines[i].Visible = false end
      else
         for _, line in pairs(lines) do line.Visible = false end
      end
   end)

   espCache[player] = {Lines = lines, Connection = connection}
end

MainTab:CreateToggle({
