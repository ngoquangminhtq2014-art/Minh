local TargetFlingToggle

TargetFlingToggle = TrollTab:CreateToggle({
   Name = "KÍCH HOẠT FLING TO TARGET",
   CurrentValue = false,
   Flag = "TargetFlingToggle",
   Callback = function(Value)
      flingActive = Value
      
      local char = LocalPlayer.Character
      local hrp = char and char:FindFirstChild("HumanoidRootPart")
      local hum = char and char:FindFirstChildOfClass("Humanoid")
      
      if flingActive then
         local targetPlayer = Players:FindFirstChild(flingTargetName)
         
         if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            Rayfield:Notify({Title = "Thất Bại", Content = "Vui lòng chọn mục tiêu hợp lệ trước!", Duration = 3})
            flingActive = false
            task.spawn(function() TargetFlingToggle:Set(false) end)
            return
         end
         
         if hrp then
            originalPos = hrp.CFrame
            Rayfield:Notify({Title = "Đang Fling", Content = "Đang quét xung lực gián tiếp...", Duration = 2})
            
            if hum then 
               hum.PlatformStand = true 
            end

            task.spawn(function()
               -- Thiết lập lực xoay cực đại phá vỡ tính toán vị trí hệ thống
               local bV = Instance.new("AngularVelocity")
               bV.Name = "IY_MaxFlingVelocity"
               bV.MaxTorque = math.huge
               bV.AngularVelocity = Vector3.new(0, 999999, 0)
               bV.Attachment0 = hrp:FindFirstChildOfClass("Attachment") or Instance.new("Attachment", hrp)
               bV.Parent = hrp

               local bG = Instance.new("BodyGyro")
               bG.Name = "IY_MaxFlingGyro"
               bG.MaxTorque = Vector3.new(1e7, 1e7, 1e7)
               bG.P = 3000
               bG.Parent = hrp

               -- Đếm thời gian để ngắt ép sát (giữ khoảng cách, không lạm dụng dính người)
               local startTime = os.clock()

               while flingActive and char and hrp.Parent and targetPlayer.Parent and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") do
                  RunService.Heartbeat:Wait()
                  
                  local targetHRP = targetPlayer.Character.HumanoidRootPart
                  local targetHum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                  
                  -- Điều kiện ngừng: Khi đối thủ chết, văng đi xa hoặc quá thời gian xử lý nhanh (1.5 giây)
                  if (targetHum and targetHum.Health <= 0) or (os.clock() - startTime > 1.5) then 
                     break 
                  end
                  
                  -- GHOST FLING: Chỉ lướt ngang cắt góc hoặc đập nhẹ chứ không dính chặt tâm hình học
                  local function getFlingCFrame()
                     return targetHRP.CFrame * CFrame.new(math.random(-1, 1), 0, math.random(-1, 1)) * CFrame.Angles(math.rad(math.random(-20,20)), math.rad(math.random(-20,20)), math.rad(math.random(-20,20)))
                  end
                  
                  hrp.CFrame = getFlingCFrame()
                  bG.CFrame = getFlingCFrame()

                  hrp.Velocity = Vector3.new(65000, 65000, 65000)
                  hrp.RotVelocity = Vector3.new(0, 65000, 0)
               end
               
               -- NGAY LẬP TỨC THU HỒI LỰC VÀ GIẬT VỀ TRÁI ĐẤT CŨ
               flingActive = false
               if bV then bV:Destroy() end
               if bG then bG:Destroy() end
               if hum then hum.PlatformStand = false end
               
               if hrp and originalPos then
                  hrp.Velocity = Vector3.new(0,0,0)
                  hrp.RotVelocity = Vector3.new(0,0,0)
                  task.wait(0.1)
                  hrp.CFrame = originalPos
                  Rayfield:Notify({Title = "Thành Công!", Content = "Đã thu hồi vị trí gốc an toàn.", Duration = 3})
               end

               -- Đặt nút gạt UI về trạng thái Off
               TargetFlingToggle:Set(false)
            end)
         end
      else
         flingActive = false
         if hum then hum.PlatformStand = false end
         if hrp then
            if hrp:FindFirstChild("IY_MaxFlingVelocity") then hrp.IY_MaxFlingVelocity:Destroy() end
            if hrp:FindFirstChild("IY_MaxFlingGyro") then hrp.IY_MaxFlingGyro:Destroy() end
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.RotVelocity = Vector3.new(0,0,0)
            if originalPos then
               task.wait(0.1)
               hrp.CFrame = originalPos
            end
         end
      end
   end,
})


