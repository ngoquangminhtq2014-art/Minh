   CurrentValue = false,
   Flag = "RealXrayToggle",
   Callback = function(Value)
      xrayEnabled = Value
      if Value then
         for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(LocalPlayer.Character) and not Players:GetPlayerFromCharacter(v.Parent) then
               if not originalTransparencies[v] then
                  originalTransparencies[v] = v.Transparency
               end
               v.Transparency = 0.5
            end
         end
      else
         for part, originalValue in pairs(originalTransparencies) do
            if part and part.Parent then
               part.Transparency = originalValue
            end
         end
         originalTransparencies = {}
      end
   end,
})

Workspace.DescendantAdded:Connect(function(v)
   if xrayEnabled and v:IsA("BasePart") and not v:IsDescendantOf(LocalPlayer.Character) and not Players:GetPlayerFromCharacter(v.Parent) then
      if not originalTransparencies[v] then
         originalTransparencies[v] = v.Transparency
      end
      v.Transparency = 0.5
   end
end)

