})

local lastCount = 0
local function UpdateDropdown()
   local currentPlayers = Players:GetPlayers()
   if #currentPlayers == lastCount then return end
   lastCount = #currentPlayers

   local tbl = {}
   for _, p in pairs(currentPlayers) do
      if p ~= LocalPlayer then table.insert(tbl, p.Name) end
   end
   PlayerDropdown:Refresh(tbl, true)
end

task.spawn(function()
   while task.wait(3) do UpdateDropdown() end
end)

