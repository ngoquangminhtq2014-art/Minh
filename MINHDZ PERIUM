-- PERFORMANCE TAB (OPTIMIZATION)
-- ==========================================

SettingsTab:CreateButton({
   Name = "🚀 Activate Lag Fixer (FPS Boost)",
   Callback = function()
      -- Optimize global environmental lighting & shadows
      Lighting.GlobalShadows = false
      Lighting.FogEnd = 9e9
      Lighting.ShadowSoftness = 0
      
      for _, effect in pairs(Lighting:GetChildren()) do
         if effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect") then
            effect.Enabled = false
         end
      end

      -- Downgrade rendering materials & terminate intensive engine particles
      for _, v in pairs(workspace:GetDescendants()) do
         if v:IsA("BasePart") and not v:IsDescendantOf(LocalPlayer.Character) then
            v.Material = Enum.Material.SmoothPlastic
         elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
         end
      end
      
      Rayfield:Notify({
         Title = "⚡ PREMIUM Boost",
         Content = "Graphics optimized successfully! FPS has been accelerated.",
         Duration = 4
      })
   end,
})

